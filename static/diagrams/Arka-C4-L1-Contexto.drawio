<mxfile host="draw.io" modified="2026-04-22T00:00:00.000Z" agent="draw.io" version="24.0.0" type="device">
  <diagram id="c1-context" name="C1 — Contexto del Sistema">
    <mxGraphModel dx="1900" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ==================== TÍTULO ==================== -->
        <mxCell id="title" value="&lt;b&gt;Diagrama de Contexto (Nivel 1)&lt;/b&gt;&lt;br&gt;Sistema E-commerce Arka" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=18;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="500" y="20" width="600" height="50" as="geometry" />
        </mxCell>

        <!-- ==================== PERSONAS ==================== -->
        <!-- Cliente B2B -->
        <mxCell id="cliente" value="&lt;b&gt;Cliente B2B&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Almacenes en LATAM que&lt;br&gt;compran accesorios para PC&lt;br&gt;en grandes cantidades.&lt;/font&gt;" style="shape=mxgraph.c4.person2;whiteSpace=wrap;html=1;container=0;align=center;verticalAlign=top;labelBackgroundColor=none;fillColor=#08427B;fontColor=#FFFFFF;strokeColor=#073B6F;fontSize=13;arcSize=50;metaEdit=1;points=[[0.5,0,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0]];" vertex="1" parent="1">
          <mxGeometry x="200" y="120" width="200" height="180" as="geometry" />
        </mxCell>

        <!-- Administrador -->
        <mxCell id="admin" value="&lt;b&gt;Administrador&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Personal interno de Arka&lt;br&gt;que gestiona inventario,&lt;br&gt;catálogo, despachos y&lt;br&gt;analiza ventas.&lt;/font&gt;" style="shape=mxgraph.c4.person2;whiteSpace=wrap;html=1;container=0;align=center;verticalAlign=top;labelBackgroundColor=none;fillColor=#08427B;fontColor=#FFFFFF;strokeColor=#073B6F;fontSize=13;arcSize=50;metaEdit=1;points=[[0.5,0,0],[1,0.5,0],[1,0.75,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,0.75,0],[0,0.5,0]];" vertex="1" parent="1">
          <mxGeometry x="1200" y="120" width="200" height="180" as="geometry" />
        </mxCell>

        <!-- ==================== SISTEMA PRINCIPAL ==================== -->
        <mxCell id="arka" value="&lt;b style=&quot;font-size:15px&quot;&gt;Plataforma E-commerce&lt;br&gt;Arka&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Plataforma central que automatiza&lt;br&gt;ventas B2B, órdenes de compra,&lt;br&gt;actualización de stock, reportes&lt;br&gt;y envíos.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;container=0;labelBackgroundColor=none;fillColor=#438DD5;fontColor=#FFFFFF;strokeColor=#3C7FC0;fontSize=13;arcSize=8;align=center;verticalAlign=middle;metaEdit=1;" vertex="1" parent="1">
          <mxGeometry x="580" y="420" width="440" height="200" as="geometry" />
        </mxCell>

        <!-- ==================== SISTEMAS EXTERNOS ==================== -->
        <!-- Identity Provider -->
        <mxCell id="idp" value="&lt;b&gt;Identity Provider (IdP)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Entra ID / AWS Cognito.&lt;br&gt;Gestiona identidad federada,&lt;br&gt;aplica Zero Trust y bloquea&lt;br&gt;dominios públicos.&lt;/font&gt;&lt;br&gt;&lt;i style=&quot;font-size:10px;color:#CCCCCC&quot;&gt;[Sistema Externo]&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;container=0;labelBackgroundColor=none;fillColor=#999999;fontColor=#FFFFFF;strokeColor=#8A8A8A;fontSize=12;arcSize=8;align=center;verticalAlign=middle;metaEdit=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="720" width="240" height="160" as="geometry" />
        </mxCell>

        <!-- Pasarelas de Pago -->
        <mxCell id="pasarelas" value="&lt;b&gt;Pasarelas de Pago&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Stripe, Wompi y Mercado Pago&lt;br&gt;para el procesamiento seguro&lt;br&gt;de transacciones en LATAM.&lt;/font&gt;&lt;br&gt;&lt;i style=&quot;font-size:10px;color:#CCCCCC&quot;&gt;[Sistema Externo]&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;container=0;labelBackgroundColor=none;fillColor=#999999;fontColor=#FFFFFF;strokeColor=#8A8A8A;fontSize=12;arcSize=8;align=center;verticalAlign=middle;metaEdit=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="720" width="240" height="160" as="geometry" />
        </mxCell>

        <!-- Sistemas de Proveedores -->
        <mxCell id="proveedores" value="&lt;b&gt;Sistemas de Proveedores&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Servicios externos para el&lt;br&gt;reabastecimiento de mercancía&lt;br&gt;que interactúan mediante&lt;br&gt;webhooks.&lt;/font&gt;&lt;br&gt;&lt;i style=&quot;font-size:10px;color:#CCCCCC&quot;&gt;[Sistema Externo]&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;container=0;labelBackgroundColor=none;fillColor=#999999;fontColor=#FFFFFF;strokeColor=#8A8A8A;fontSize=12;arcSize=8;align=center;verticalAlign=middle;metaEdit=1;" vertex="1" parent="1">
          <mxGeometry x="600" y="720" width="240" height="160" as="geometry" />
        </mxCell>

        <!-- API Logística Externa -->
        <mxCell id="shippingAPI" value="&lt;b&gt;API Logística Externa&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Operadores logísticos de terceros&lt;br&gt;(FedEx, DHL, etc.) encargados&lt;br&gt;del cálculo de envíos y&lt;br&gt;generación de guías.&lt;/font&gt;&lt;br&gt;&lt;i style=&quot;font-size:10px;color:#CCCCCC&quot;&gt;[Sistema Externo]&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;container=0;labelBackgroundColor=none;fillColor=#999999;fontColor=#FFFFFF;strokeColor=#8A8A8A;fontSize=12;arcSize=8;align=center;verticalAlign=middle;metaEdit=1;" vertex="1" parent="1">
          <mxGeometry x="880" y="720" width="240" height="160" as="geometry" />
        </mxCell>

        <!-- AWS SES -->
        <mxCell id="ses" value="&lt;b&gt;AWS SES&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Servicio gestionado para el envío&lt;br&gt;de correos electrónicos&lt;br&gt;transaccionales (confirmaciones,&lt;br&gt;estados, carritos abandonados).&lt;/font&gt;&lt;br&gt;&lt;i style=&quot;font-size:10px;color:#CCCCCC&quot;&gt;[Sistema Externo]&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;container=0;labelBackgroundColor=none;fillColor=#999999;fontColor=#FFFFFF;strokeColor=#8A8A8A;fontSize=12;arcSize=8;align=center;verticalAlign=middle;metaEdit=1;" vertex="1" parent="1">
          <mxGeometry x="1160" y="720" width="240" height="160" as="geometry" />
        </mxCell>

        <!-- ==================== RELACIONES ==================== -->
        <!-- Cliente → Arka -->
        <mxCell id="rel_cliente_arka" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.25;entryY=0;entryDx=0;entryDy=0;strokeColor=#707070;strokeWidth=2;fontColor=#707070;fontSize=11;" edge="1" parent="1" source="cliente" target="arka">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="rel_cliente_arka_label" value="Busca productos, gestiona carrito,&lt;br&gt;crea órdenes y hace seguimiento&lt;br&gt;&lt;i&gt;[HTTPS/REST]&lt;/i&gt;" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontColor=#707070;" vertex="1" connectable="0" parent="rel_cliente_arka">
          <mxGeometry x="-0.1" relative="1" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- Admin → Arka -->
