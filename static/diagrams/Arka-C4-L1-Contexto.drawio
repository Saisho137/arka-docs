          </mxGeometry>
        </mxCell>

        <!-- Arka → Proveedores -->
        <mxCell id="rel_arka_proveedores" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#707070;strokeWidth=2;fontColor=#707070;fontSize=11;" edge="1" parent="1" source="arka" target="proveedores">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="rel_arka_proveedores_label" value="Intercambia presupuestos y&lt;br&gt;recibe notificaciones de stock&lt;br&gt;&lt;i&gt;[HTTPS/Webhooks]&lt;/i&gt;" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontColor=#707070;" vertex="1" connectable="0" parent="rel_arka_proveedores">
          <mxGeometry x="-0.1" relative="1" as="geometry">
