          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="rel_admin_arka_label" value="Actualiza stock, registra productos,&lt;br&gt;despacha y consulta analíticas&lt;br&gt;&lt;i&gt;[HTTPS/REST]&lt;/i&gt;" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontColor=#707070;" vertex="1" connectable="0" parent="rel_admin_arka">
          <mxGeometry x="-0.1" relative="1" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
